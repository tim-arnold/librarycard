# API URL for your Cloudflare Worker
# For local development (default)
NEXT_PUBLIC_API_URL=http://localhost:8787

# For production environments - uncomment and update the line below
# NEXT_PUBLIC_API_URL=https://your-worker-url.workers.dev

# NextAuth.js Configuration
# For local development
NEXTAUTH_URL=http://localhost:3000
# For production - update with your actual URL
# NEXTAUTH_URL=https://your-app-url.netlify.app

# 🔐 SECURE SETUP OPTION 1: 1Password Integration (Recommended)
# Use 1Password CLI to securely manage sensitive environment variables
# Setup: ./scripts/setup-1password-secrets.sh
# Update: ./scripts/update-env-with-1password.sh
# Run app: op run --env-file=".env.local" -- npm run dev
#
# NEXTAUTH_SECRET="op://LibraryCard/NextAuth Secret/password"
# GOOGLE_CLIENT_ID="op://LibraryCard/Google Client ID/password"
# GOOGLE_CLIENT_SECRET="op://LibraryCard/Google Client Secret/password"
# GOOGLE_CLOUD_PROJECT_ID="op://LibraryCard/Google Cloud Project ID/password"
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="op://LibraryCard/Turnstile Site Key/password"
# TURNSTILE_SECRET_KEY="op://LibraryCard/Turnstile Secret Key/password"
# CLOUDFLARE_API_TOKEN_STAGING_="op://LibraryCard/Cloudflare API Token Staging/password"
# CLOUDFLARE_API_TOKEN_STAGING_NEW="op://LibraryCard/Cloudflare API Token Staging New/password"

# 🔑 MANUAL SETUP OPTION 2: Direct Values (Less Secure)
# If not using 1Password, provide values directly:
NEXTAUTH_SECRET=your-secret-key-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CLOUD_PROJECT_ID=your-project-id
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
CLOUDFLARE_API_TOKEN_STAGING_=your-cloudflare-api-token-for-staging
CLOUDFLARE_API_TOKEN_STAGING_NEW=your-cloudflare-api-token-for-staging-new

# Google Cloud Vision API (for OCR features)
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json

# Screenshot Testing (for automated UI testing)
SCREENSHOT_USER=superadmin@localhost
SCREENSHOT_PASSWORD=Super123!

# Local Development Users (created by setup script)
LOCAL_SUPERADMIN=superadmin@localhost
LOCAL_SUPERADMIN_PASSWORD=Super123!

LOCAL_ADMIN=adminuser@localhost
LOCAL_ADMIN_PASSWORD=Admin123!

LOCAL_USER=testuser@localhost
LOCAL_USER_PASSWORD=Test123!