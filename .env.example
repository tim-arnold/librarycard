# API URL for your Cloudflare Worker
# IMPORTANT: This must be set in production environments
# For Netlify: Set this in your site's environment variables dashboard
NEXT_PUBLIC_API_URL=https://your-worker-url.workers.dev

# For local development
# NEXT_PUBLIC_API_URL=http://localhost:8787

# Production (set via Netlify environment variables)
# NEXT_PUBLIC_API_URL=https://your-production-worker-url.workers.dev

# NextAuth.js Configuration
NEXTAUTH_URL=https://your-app-url.netlify.app
NEXTAUTH_SECRET=your-secret-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Cloud Vision API (removed - OCR feature no longer supported)
# GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json
# GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Screenshot Testing (for automated UI testing)
SCREENSHOT_USER=your-test-email@example.com
SCREENSHOT_PASSWORD=your-test-password

# Cloudflare Turnstile (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key