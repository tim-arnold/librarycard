# API URL for your Cloudflare Worker
# For local development (default)
NEXT_PUBLIC_API_URL=http://localhost:8787

# For production environments - uncomment and update the line below
# NEXT_PUBLIC_API_URL=https://your-worker-url.workers.dev

# NextAuth.js Configuration
# For local development
NEXTAUTH_URL=http://localhost:3000
# For production - update with your actual URL
# NEXTAUTH_URL=https://your-app-url.netlify.app

# Generate a random secret key for NextAuth.js
NEXTAUTH_SECRET=your-secret-key-here

# Google OAuth (required for Google sign-in)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Cloud Vision API (for OCR features)
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Screenshot Testing (for automated UI testing)
SCREENSHOT_USER=superadmin@localhost
SCREENSHOT_PASSWORD=Super123!

# Local Development Users (created by setup script)
LOCAL_SUPERADMIN=superadmin@localhost
LOCAL_SUPERADMIN_PASSWORD=Super123!

LOCAL_ADMIN=adminuser@localhost
LOCAL_ADMIN_PASSWORD=Admin123!

LOCAL_USER=testuser@localhost
LOCAL_USER_PASSWORD=Test123!

# Cloudflare Turnstile (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key