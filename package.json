{
  "name": "librarycard",
  "version": "1.0.1",
  "description": "Personal library management app with ISBN scanning",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "seed-local": "node scripts/seed-local-data.js",
    "setup-local": "node scripts/setup-local-db.js",
    "dev-worker": "npx wrangler dev --env local --port 8787",
    "deploy:prod": "node scripts/prod-deploy.js",
    "migrate:prod": "node scripts/prod-migrate.js",
    "validate:env": "node scripts/validate-environment.js",
    "switch-domain": "node scripts/switch-domain.js",
    "validate-domain-config": "node scripts/validate-domain-config.js",
    "backup:create": "node scripts/auto-backup.js create",
    "backup:list": "node scripts/auto-backup.js list",
    "backup:verify": "node scripts/auto-backup.js verify",
    "backup:restore": "node scripts/restore-backup.js",
    "backup:staging:create": "node scripts/backup-staging.js create",
    "backup:staging:list": "node scripts/backup-staging.js list",
    "backup:staging:verify": "node scripts/backup-staging.js verify",
    "backup:staging:restore": "node scripts/restore-staging.js",
    "backup:production:create": "echo '🚨 BLOCKED: Production backup only via GitHub Actions \"💾 Production Cloudflare Workers & D1 Backup\"' && exit 1",
    "backup:production:list": "echo '🚨 BLOCKED: Production operations only via GitHub Actions' && exit 1",
    "backup:production:verify": "echo '🚨 BLOCKED: Production operations only via GitHub Actions' && exit 1",
    "backup:production:restore": "echo '🚨 BLOCKED: Production restore requires PRODUCTION_RESTORE_OVERRIDE=true for emergency use only' && exit 1",
    "test:prod-restore": "node scripts/test-prod-restore-to-staging.js",
    "deploy:staging": "wrangler deploy --env=staging",
    "deploy:staging-new": "CLOUDFLARE_API_TOKEN=$CLOUDFLARE_API_TOKEN_STAGING_NEW wrangler deploy --config=wrangler.staging-new.toml --env=staging",
    "migrate": "node scripts/migrate.js migrate",
    "migrate:status": "node scripts/migrate.js status",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "migrate:rollback:local": "MIGRATION_ENV=local node scripts/migrate.js rollback",
    "migrate:rollback:staging": "MIGRATION_ENV=staging-new node scripts/migrate.js rollback",
    "migrate:rollback:production": "MIGRATION_ENV=production node scripts/migrate.js rollback",
    "migrate:local": "MIGRATION_ENV=local node scripts/migrate.js migrate",
    "migrate:staging": "MIGRATION_ENV=staging-new node scripts/migrate.js migrate",
    "migrate:production": "MIGRATION_ENV=production node scripts/migrate.js migrate",
    "migrate:dry-run": "node scripts/migrate.js migrate --dry-run"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@eslint/eslintrc": "^3.3.5",
    "@marsidev/react-turnstile": "^1.1.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@otplib/preset-browser": "^12.0.1",
    "@otplib/preset-default": "^12.0.1",
    "@simplewebauthn/browser": "^13.1.2",
    "@simplewebauthn/server": "^13.1.2",
    "@simplewebauthn/types": "^12.0.0",
    "@tanstack/react-query": "^5.84.1",
    "@zxing/library": "^0.21.3",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "jose": "^6.0.12",
    "next": "^16.2.1",
    "next-auth": "^4.24.13",
    "nodemailer": "^8.0.4",
    "qrcode": "^1.5.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-easy-crop": "^5.5.1",
    "react-window": "^1.8.11",
    "uuid": "^11.1.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250603.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "puppeteer": "^24.10.0",
    "typescript": "^5.5.3",
    "wrangler": "^4.27.0"
  },
  "private": true
}
